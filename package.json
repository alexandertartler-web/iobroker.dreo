{
  "name": "iobroker.dreo",
  "version": "0.0.10",
  "description": "ioBroker adapter for Dreo smart devices using the native Dreo Cloud API.",
  "author": "Alexander Tartler",
  "contributors": [
    "ioBroker Community"
  ],
  "license": "MIT",
  "homepage": "https://github.com/alexandertartler-web/ioBroker.dreo",
  "bugs": {
    "url": "https://github.com/alexandertartler-web/ioBroker.dreo/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexandertartler-web/ioBroker.dreo.git"
  },
  "files": [
    "admin",
    "build",
    "vis",
    "io-package.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ioBroker",
    "dreo",
    "heater",
    "smarthome"
  ],
  "main": "build/main.js",
  "types": "build/main.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -w -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build",
    "test:package": "npm pack --dry-run",
    "check": "npx @iobroker/repochecker https://github.com/alexandertartler-web/ioBroker.dreo main",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "axios": "^1.16.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@iobroker/testing": "^5.2.2",
    "@types/node": "^20.17.57",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  }
}
